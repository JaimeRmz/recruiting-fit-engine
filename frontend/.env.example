# Copy this file to .env.local and paste your real key.
# .env.local is gitignored, so the real key never gets committed.
#
#   cp .env.example .env.local
#   # then edit .env.local and set VITE_API_KEY
#
# This is the same value set as API_SECRET_KEY in the Render dashboard.
# It is sent as the X-API-Key header on /api/moments requests only.
VITE_API_KEY=your-api-key-here

# Optional: override the deployed API base URL (defaults to the Render service).
# VITE_API_BASE=https://recruiting-fit-engine-api.onrender.com
